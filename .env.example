# Database
DATABASE_URL="postgresql://vibecoder:vibecoder@localhost:5432/app"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth (nuxt-auth-utils uses NUXT_SESSION_PASSWORD)
NUXT_SESSION_PASSWORD="at-least-32-characters-long-random-string"
AUTH_SECRET="generate-a-random-secret-here"

# Stripe (optional — app works without it)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Resend (optional — app works without it)
RESEND_API_KEY=""

# UploadThing (optional — app works without it)
UPLOADTHING_TOKEN=""

# App
APP_URL="http://localhost:3000"
NODE_ENV="development"
